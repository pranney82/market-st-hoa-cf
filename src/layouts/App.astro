---
import Base from "./Base.astro";

interface Props {
  title: string;
}
const { title } = Astro.props;
const user = Astro.locals.user!;
const path = Astro.url.pathname;

const nav = [
  { href: "/dashboard", label: "Dashboard", icon: "home" },
  { href: "/payments", label: "Payments", icon: "credit-card" },
  { href: "/events", label: "Events", icon: "calendar" },
  { href: "/announcements", label: "Announcements", icon: "megaphone" },
  { href: "/documents", label: "Documents", icon: "file-text" },
  { href: "/requests", label: "Requests", icon: "clipboard" },
  { href: "/bylaws", label: "Bylaws", icon: "book" },
  { href: "/members", label: "Members", icon: "users" },
];

const adminNav = [
  { href: "/households", label: "Households", icon: "building" },
  { href: "/financials", label: "Financials", icon: "bar-chart" },
  { href: "/admin/accounts", label: "Accounts", icon: "layers" },
];

const isAdmin = user.role === "admin" || user.role === "board";
---
<Base title={title} class="bg-gray-50 min-h-screen">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <aside class="w-64 bg-white border-r border-gray-200 flex flex-col shrink-0 hidden md:flex">
      <div class="p-4 border-b border-gray-200">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 bg-blue-600 rounded-md flex items-center justify-center text-white text-sm font-bold">M</div>
          <span class="font-semibold text-sm">Market St HOA</span>
        </div>
      </div>

      <nav class="flex-1 p-3 space-y-1">
        {nav.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              "block px-3 py-2 rounded-md text-sm transition-colors",
              path === href ? "bg-blue-50 text-blue-700 font-medium" : "text-gray-600 hover:bg-gray-100"
            ]}
          >
            {label}
          </a>
        ))}

        {isAdmin && (
          <>
            <div class="pt-4 pb-1 px-3 text-xs font-medium text-gray-400 uppercase">Admin</div>
            {adminNav.map(({ href, label }) => (
              <a
                href={href}
                class:list={[
                  "block px-3 py-2 rounded-md text-sm transition-colors",
                  path === href ? "bg-blue-50 text-blue-700 font-medium" : "text-gray-600 hover:bg-gray-100"
                ]}
              >
                {label}
              </a>
            ))}
          </>
        )}
      </nav>

      <div class="p-4 border-t border-gray-200">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 bg-gray-200 rounded-full flex items-center justify-center text-xs font-medium text-gray-600">
            {user.firstName?.[0]}{user.lastName?.[0]}
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900 truncate">{user.firstName} {user.lastName}</p>
            <p class="text-xs text-gray-500 truncate">{user.email}</p>
          </div>
        </div>
        <a href="/settings" class="block mt-3 text-xs text-gray-500 hover:text-gray-700">Settings</a>
        <form method="POST" action="/api/logout" class="mt-1">
          <button type="submit" class="text-xs text-red-500 hover:text-red-700">Sign out</button>
        </form>
      </div>
    </aside>

    <!-- Main content -->
    <main class="flex-1 p-6 overflow-y-auto">
      <slot />
    </main>
  </div>
</Base>
