---
// Reads success/error from URL search params and renders a toast notification
const success = Astro.url.searchParams.get("success");
const error = Astro.url.searchParams.get("error");

const messages: Record<string, string> = {
  profile: "Profile updated successfully.",
  password: "Password changed successfully.",
  comment: "Comment added.",
  status: "Status updated.",
  rsvp: "RSVP updated.",
  vote: "Vote recorded.",
  request: "Request submitted.",
};

const message = success ? (messages[success] || success) : error || null;
const type = success ? "success" : "error";
---

{message && (
  <div
    id="toast"
    role="alert"
    aria-live="polite"
    class:list={[
      "fixed top-4 right-4 z-[100] max-w-sm px-4 py-3 rounded-xl shadow-lg border text-sm font-medium",
      "transform transition-all duration-300 translate-y-0 opacity-100",
      "md:top-6 md:right-6",
      type === "success"
        ? "bg-green-50 dark:bg-green-900/30 border-green-200 dark:border-green-800 text-green-700 dark:text-green-300"
        : "bg-red-50 dark:bg-red-900/30 border-red-200 dark:border-red-800 text-red-700 dark:text-red-300"
    ]}
  >
    <div class="flex items-center gap-2">
      {type === "success" ? (
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      ) : (
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      )}
      <span>{message}</span>
      <button
        id="toast-close"
        class="ml-auto -mr-1 p-1 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 transition-colors"
        aria-label="Dismiss"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>
)}

<script is:inline>
  const toast = document.getElementById('toast');
  if (toast) {
    // Auto-dismiss after 4 seconds
    const timer = setTimeout(() => {
      toast.style.opacity = '0';
      toast.style.transform = 'translateY(-1rem)';
      setTimeout(() => toast.remove(), 300);
    }, 4000);

    document.getElementById('toast-close')?.addEventListener('click', () => {
      clearTimeout(timer);
      toast.style.opacity = '0';
      toast.style.transform = 'translateY(-1rem)';
      setTimeout(() => toast.remove(), 300);
    });

    // Clean URL params without reload
    const url = new URL(window.location.href);
    url.searchParams.delete('success');
    url.searchParams.delete('error');
    window.history.replaceState({}, '', url.toString());
  }
</script>
