---
interface Props {
  class?: string;
  variant?: "text" | "card" | "circle" | "table-row";
  count?: number;
}
const { class: className = "", variant = "text", count = 1 } = Astro.props;
---

{variant === "text" && Array.from({ length: count }).map(() => (
  <div class:list={["animate-pulse rounded-md bg-gray-200 h-4", className]} />
))}

{variant === "card" && Array.from({ length: count }).map(() => (
  <div class:list={["animate-pulse rounded-xl border border-gray-200 bg-white p-5", className]}>
    <div class="h-4 bg-gray-200 rounded w-1/3 mb-3" />
    <div class="h-3 bg-gray-200 rounded w-2/3 mb-2" />
    <div class="h-3 bg-gray-200 rounded w-1/2" />
  </div>
))}

{variant === "circle" && Array.from({ length: count }).map(() => (
  <div class:list={["animate-pulse rounded-full bg-gray-200 w-8 h-8", className]} />
))}

{variant === "table-row" && Array.from({ length: count }).map(() => (
  <div class="animate-pulse flex items-center gap-4 px-4 py-3">
    <div class="h-3 bg-gray-200 rounded flex-1" />
    <div class="h-3 bg-gray-200 rounded w-20" />
    <div class="h-3 bg-gray-200 rounded w-16" />
    <div class="h-3 bg-gray-200 rounded w-12" />
  </div>
))}
