---
import App from "../../layouts/App.astro";
import { getDb } from "../../lib/db";
import { architecturalRequests, requestComments, users } from "../../../shared/schema";
import { eq, desc } from "drizzle-orm";
import { format } from "date-fns";

const { id } = Astro.params;
const user = Astro.locals.user!;
const isAdmin = user.role === "admin" || user.role === "board";
const db = getDb(Astro.locals.runtime.env);

const [req] = await db.select().from(architecturalRequests).where(eq(architecturalRequests.id, id!));
if (!req) return Astro.redirect("/requests");

if (!isAdmin && req.submittedBy !== user.id) return Astro.redirect("/requests");

const [submitter] = await db.select({ firstName: users.firstName, lastName: users.lastName }).from(users).where(eq(users.id, req.submittedBy));

const comments = await db
 .select({ comment: requestComments, author: { firstName: users.firstName, lastName: users.lastName } })
 .from(requestComments)
 .leftJoin(users, eq(requestComments.userId, users.id))
 .where(eq(requestComments.requestId, id!))
 .orderBy(requestComments.createdAt);

const statusColors: Record<string, string> = { pending: "bg-yellow-100 text-yellow-700", approved: "bg-green-100 text-green-700", denied: "bg-red-100 text-red-700" };
const success = Astro.url.searchParams.get("success");
---
<App title={req.title}>
 <div class="max-w-3xl">
 <a href="/requests" class="text-sm text-blue-600 hover:underline mb-4 inline-block">&larr; All Requests</a>

 {success && <div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">{success === "comment" ? "Comment added." : success === "status" ? "Status updated." : "Done."}</div>}

 <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
 <div class="flex items-start justify-between mb-4">
 <div>
 <h1 class="text-xl font-bold text-gray-900">{req.title}</h1>
 <p class="text-sm text-gray-500 mt-1">{submitter?.firstName} {submitter?.lastName} · {format(new Date(req.createdAt!), "MMM d, yyyy")}</p>
 </div>
 <span class:list={["text-xs font-medium px-3 py-1 rounded-full", statusColors[req.status] || "bg-gray-100 text-gray-600"]}>{req.status}</span>
 </div>
 <p class="text-sm text-gray-700 whitespace-pre-wrap">{req.description}</p>
 {req.reviewNotes && (
 <div class="mt-4 p-3 bg-gray-50 rounded-lg">
 <p class="text-xs font-medium text-gray-500 mb-1">Review Notes</p>
 <p class="text-sm text-gray-700">{req.reviewNotes}</p>
 </div>
 )}
 </div>

 {isAdmin && req.status === "pending" && (
 <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
 <h2 class="font-semibold text-gray-900 mb-3">Review</h2>
 <form method="POST" action="/api/requests/review" class="space-y-3">
 <input type="hidden" name="requestId" value={req.id} />
 <div>
 <label class="block text-sm font-medium text-gray-700 mb-1">Notes</label>
 <textarea name="reviewNotes" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm"></textarea>
 </div>
 <div class="flex gap-2">
 <button type="submit" name="status" value="approved" class="px-4 py-2 bg-green-600 text-white rounded-lg text-sm font-medium hover:bg-green-700">Approve</button>
 <button type="submit" name="status" value="denied" class="px-4 py-2 bg-red-600 text-white rounded-lg text-sm font-medium hover:bg-red-700">Deny</button>
 </div>
 </form>
 </div>
 )}

 <div class="bg-white rounded-xl border border-gray-200 p-5">
 <h2 class="font-semibold text-gray-900 mb-4">Comments ({comments.length})</h2>
 {comments.length > 0 && (
 <div class="space-y-3 mb-4">
 {comments.map(({ comment: c, author: a }) => (
 <div class="border-b border-gray-100 pb-3 last:border-0">
 <div class="flex items-center gap-2 mb-1">
 <span class="text-sm font-medium text-gray-900">{a?.firstName} {a?.lastName}</span>
 <span class="text-xs text-gray-400">{format(new Date(c.createdAt!), "MMM d 'at' h:mm a")}</span>
 </div>
 <p class="text-sm text-gray-700">{c.comment}</p>
 </div>
 ))}
 </div>
 )}
 <form method="POST" action="/api/requests/comment" class="flex gap-2">
 <input type="hidden" name="requestId" value={req.id} />
 <input type="text" name="comment" required placeholder="Add a comment..." class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm" />
 <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700">Post</button>
 </form>
 </div>
 </div>
</App>
