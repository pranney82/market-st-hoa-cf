---
import App from "../layouts/App.astro";
import { getDb } from "../lib/db";
import { users } from "../../shared/schema";
import { eq } from "drizzle-orm";

const db = getDb(Astro.locals.runtime.env);
const members = await db.select().from(users).where(eq(users.memberStatus, "active"));
---
<App title="Members">
  <div class="max-w-4xl">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Members</h1>

    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900">
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Name</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Email</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Address</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Role</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
          {members.map((m) => (
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
              <td class="px-4 py-3">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center text-xs font-medium text-blue-700">
                    {m.firstName?.[0]}{m.lastName?.[0]}
                  </div>
                  <span class="text-sm font-medium text-gray-900 dark:text-white">{m.firstName} {m.lastName}</span>
                </div>
              </td>
              <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-400">{m.email}</td>
              <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-400">{m.address}</td>
              <td class="px-4 py-3">
                <span class:list={[
                  "text-xs font-medium px-2 py-1 rounded-full",
                  m.role === "admin" ? "bg-purple-100 text-purple-700" :
                  m.role === "board" ? "bg-blue-100 text-blue-700" :
                  "bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300"
                ]}>
                  {m.role}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</App>
