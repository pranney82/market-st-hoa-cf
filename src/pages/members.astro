---
import App from "../layouts/App.astro";
import { getDb } from "../lib/db";
import { users } from "../../shared/schema";
import { eq } from "drizzle-orm";

const user = Astro.locals.user!;
const db = getDb(Astro.locals.runtime.env);

// All members can see the directory, but only admin/board see email + address
const isAdmin = user.role === "admin" || user.role === "board";
const members = await db.select().from(users).where(eq(users.memberStatus, "active"));
---
<App title="Members">
  <div class="max-w-4xl">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">Members</h1>

    {members.length === 0 ? (
      <div class="bg-white rounded-xl border border-gray-200 p-8 text-center text-gray-500">
        No active members.
      </div>
    ) : (
      <>
        {/* Desktop table */}
        <div class="hidden md:block bg-white rounded-xl border border-gray-200 overflow-hidden">
          <table class="w-full">
            <thead>
              <tr class="border-b border-gray-200 bg-gray-50">
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
                {isAdmin && <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>}
                {isAdmin && <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Address</th>}
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Role</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {members.map((m) => (
                <tr class="hover:bg-gray-50">
                  <td class="px-4 py-3">
                    <div class="flex items-center gap-3">
                      <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center text-xs font-medium text-blue-700">
                        {m.firstName?.[0]}{m.lastName?.[0]}
                      </div>
                      <span class="text-sm font-medium text-gray-900">{m.firstName} {m.lastName}</span>
                    </div>
                  </td>
                  {isAdmin && <td class="px-4 py-3 text-sm text-gray-600">{m.email}</td>}
                  {isAdmin && <td class="px-4 py-3 text-sm text-gray-600">{m.address}</td>}
                  <td class="px-4 py-3">
                    <span class:list={[
                      "text-xs font-medium px-2 py-1 rounded-full",
                      m.role === "admin" ? "bg-purple-100 text-purple-700" :
                      m.role === "board" ? "bg-blue-100 text-blue-700" :
                      "bg-gray-100 text-gray-600"
                    ]}>
                      {m.role}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        {/* Mobile cards */}
        <div class="md:hidden space-y-3">
          {members.map((m) => (
            <div class="bg-white rounded-xl border border-gray-200 p-4">
              <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center text-sm font-medium text-blue-700">
                  {m.firstName?.[0]}{m.lastName?.[0]}
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-semibold text-gray-900">{m.firstName} {m.lastName}</p>
                  {isAdmin && <p class="text-xs text-gray-500 truncate">{m.email}</p>}
                </div>
                <span class:list={[
                  "text-xs font-medium px-2 py-1 rounded-full shrink-0",
                  m.role === "admin" ? "bg-purple-100 text-purple-700" :
                  m.role === "board" ? "bg-blue-100 text-blue-700" :
                  "bg-gray-100 text-gray-600"
                ]}>
                  {m.role}
                </span>
              </div>
              {isAdmin && m.address && (
                <p class="text-xs text-gray-500 pl-[52px] truncate">{m.address}</p>
              )}
            </div>
          ))}
        </div>
      </>
    )}
  </div>
</App>
