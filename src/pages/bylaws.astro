---
import App from "../layouts/App.astro";
import BylawsChat from "../components/BylawsChat";
import { getDb } from "../lib/db";
import { bylaws } from "../../shared/schema";
import { eq, desc } from "drizzle-orm";

const db = getDb(Astro.locals.runtime.env);
const [currentBylaws] = await db
  .select()
  .from(bylaws)
  .where(eq(bylaws.isCurrent, true))
  .orderBy(desc(bylaws.createdAt))
  .limit(1);
---
<App title="Bylaws">
  <div class="max-w-4xl">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">Community Bylaws</h1>

    <!-- React island: AI chat (only JS on this page) -->
    <div class="mb-6">
      <BylawsChat client:load />
    </div>

    <!-- Server-rendered bylaws content: zero JS -->
    {currentBylaws ? (
      <div class="bg-white rounded-xl border border-gray-200 p-6">
        <div class="flex justify-between items-center mb-4">
          <h2 class="font-semibold text-gray-900">Version {currentBylaws.version}</h2>
          {currentBylaws.notes && (
            <span class="text-xs text-gray-500">{currentBylaws.notes}</span>
          )}
        </div>
        <div class="prose prose-sm max-w-none text-gray-700 whitespace-pre-wrap">{currentBylaws.content}</div>
      </div>
    ) : (
      <div class="bg-white rounded-xl border border-gray-200 p-6 text-center text-gray-500">
        No bylaws have been published yet.
      </div>
    )}
  </div>
</App>
