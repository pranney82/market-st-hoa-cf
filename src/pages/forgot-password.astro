---
import Base from "../layouts/Base.astro";
import Csrf from "../components/Csrf.astro";

const sent = Astro.url.searchParams.get("sent");
---
<Base title="Forgot Password">
  <div class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
    <div class="w-full max-w-sm">
      <div class="text-center mb-8">
        <h1 class="text-2xl font-bold text-gray-900">Reset password</h1>
        <p class="text-sm text-gray-500 mt-1">We'll send you a reset link</p>
      </div>
      {sent && <div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700">If that email exists, a reset link has been sent.</div>}
      <form method="POST" action="/api/auth/request-password-reset" class="space-y-4">
        <Csrf />
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <input type="email" name="email" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm" />
        </div>
        <button type="submit" class="w-full py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700">Send Reset Link</button>
      </form>
      <p class="mt-4 text-center text-sm text-gray-500"><a href="/login" class="text-blue-600 hover:underline">Back to sign in</a></p>
    </div>
  </div>
</Base>
