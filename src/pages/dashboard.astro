---
import App from "../layouts/App.astro";
import DuesChart from "../components/DuesChart";
import { getDb } from "../lib/db";
import { duesPayments, ballots, architecturalRequests, documents } from "../../shared/schema";
import { eq, desc, and, inArray, sql, gte } from "drizzle-orm";
import { format } from "date-fns";

const user = Astro.locals.user!;
const db = getDb(Astro.locals.runtime.env);

// Fetch everything in parallel — data arrives with the HTML
const [pendingDues, allDues, activeBallots, recentRequests, recentDocs] = await Promise.all([
  db.select().from(duesPayments).where(
    and(eq(duesPayments.userId, user.id), inArray(duesPayments.status, ["pending", "overdue"]))
  ).orderBy(duesPayments.dueDate).limit(5),
  db.select().from(duesPayments).where(eq(duesPayments.userId, user.id)).orderBy(desc(duesPayments.periodStart)).limit(12),
  db.select({ count: sql<number>`count(*)` }).from(ballots).where(
    and(eq(ballots.status, "active"), gte(ballots.endsAt, new Date().toISOString()))
  ),
  db.select().from(architecturalRequests).where(eq(architecturalRequests.submittedBy, user.id)).orderBy(desc(architecturalRequests.createdAt)).limit(3),
  db.select().from(documents).orderBy(desc(documents.createdAt)).limit(3),
]);

const totalOwed = pendingDues.reduce((sum, d) => sum + parseFloat(d.amount), 0);
const ballotCount = activeBallots[0]?.count || 0;
const chartData = allDues.map(d => ({
  description: d.description || "Monthly Dues",
  amount: d.amount,
  status: d.status,
  periodStart: d.periodStart,
}));
---
<App title="Dashboard">
  <div class="max-w-5xl">
    <h1 class="text-2xl font-bold text-gray-900 mb-1">Welcome back, {user.firstName}</h1>
    <p class="text-sm text-gray-500 mb-6">{format(new Date(), "EEEE, MMMM d, yyyy")}</p>

    <!-- Stats row -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 mb-6">
      <div class="bg-white rounded-xl border border-gray-200 p-4 md:p-5">
        <p class="text-xs md:text-sm text-gray-500">Balance Due</p>
        <p class:list={["text-xl md:text-2xl font-bold mt-1", totalOwed > 0 ? "text-red-600" : "text-green-600"]}>
          ${totalOwed.toFixed(2)}
        </p>
        {totalOwed > 0 && <a href="/payments" class="text-xs md:text-sm text-blue-600 hover:underline mt-1 inline-block">Pay now &rarr;</a>}
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-4 md:p-5">
        <p class="text-xs md:text-sm text-gray-500">Pending Dues</p>
        <p class="text-xl md:text-2xl font-bold text-gray-900 mt-1">{pendingDues.length}</p>
        <a href="/payments" class="text-xs md:text-sm text-blue-600 hover:underline mt-1 inline-block">View details</a>
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-4 md:p-5">
        <p class="text-xs md:text-sm text-gray-500">Active Ballots</p>
        <p class="text-xl md:text-2xl font-bold text-gray-900 mt-1">{ballotCount}</p>
        {ballotCount > 0 && <a href="/voting" class="text-xs md:text-sm text-blue-600 hover:underline mt-1 inline-block">Vote now</a>}
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-4 md:p-5">
        <p class="text-xs md:text-sm text-gray-500">My Requests</p>
        <p class="text-xl md:text-2xl font-bold text-gray-900 mt-1">{recentRequests.length}</p>
        <a href="/requests" class="text-xs md:text-sm text-blue-600 hover:underline mt-1 inline-block">View all</a>
      </div>
    </div>

    <!-- Dues chart -->
    {chartData.length > 0 && (
      <div class="bg-white rounded-xl border border-gray-200 p-5 mb-6">
        <h2 class="font-semibold text-gray-900 mb-4">Dues History</h2>
        <DuesChart client:idle dues={chartData} />
      </div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 md:gap-6">
      <!-- Pending Dues -->
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <div class="flex justify-between items-center mb-4">
          <h2 class="font-semibold text-gray-900">Outstanding Dues</h2>
          <a href="/payments" class="text-sm text-blue-600 hover:underline">View all</a>
        </div>
        {pendingDues.length === 0 ? (
          <div class="text-center py-4">
            <svg class="w-8 h-8 mx-auto text-green-500 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-sm text-gray-500">You're all caught up!</p>
          </div>
        ) : (
          <div class="space-y-2">
            {pendingDues.map((d) => (
              <div class="flex items-center justify-between py-2 border-b border-gray-100 last:border-0">
                <div>
                  <p class="text-sm font-medium text-gray-900">{d.description || "Monthly Dues"}</p>
                  <p class="text-xs text-gray-500">Due {format(new Date(d.dueDate), "MMM d, yyyy")}</p>
                </div>
                <div class="text-right">
                  <p class="text-sm font-semibold text-gray-900">${parseFloat(d.amount).toFixed(2)}</p>
                  <span class:list={[
                    "text-xs font-medium px-2 py-0.5 rounded-full",
                    d.status === "overdue" ? "bg-red-100 text-red-700" : "bg-yellow-100 text-yellow-700"
                  ]}>{d.status}</span>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Recent Documents -->
      <div class="bg-white rounded-xl border border-gray-200 p-5">
        <div class="flex justify-between items-center mb-4">
          <h2 class="font-semibold text-gray-900">Recent Documents</h2>
          <a href="/documents" class="text-sm text-blue-600 hover:underline">View all</a>
        </div>
        {recentDocs.length === 0 ? (
          <p class="text-sm text-gray-500">No documents yet.</p>
        ) : (
          <div class="space-y-2">
            {recentDocs.map((d) => (
              <a href={`/api/documents/${d.id}/download`} class="flex items-center gap-3 py-2 border-b border-gray-100 last:border-0 hover:bg-gray-50 -mx-2 px-2 rounded-lg transition-colors">
                <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium text-gray-900 truncate">{d.fileName}</p>
                  <p class="text-xs text-gray-500">{d.category} · {format(new Date(d.createdAt!), "MMM d")}</p>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</App>
