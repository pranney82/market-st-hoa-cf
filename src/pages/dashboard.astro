---
import App from "../layouts/App.astro";
import { getDb } from "../lib/db";
import { announcements, duesPayments } from "../../shared/schema";
import { eq, desc, and } from "drizzle-orm";
import { format } from "date-fns";

const user = Astro.locals.user!;
const db = getDb(Astro.locals.runtime.env);

// Fetch everything in parallel — data arrives with the HTML
const [recentAnnouncements, myDues] = await Promise.all([
  db.select().from(announcements).orderBy(desc(announcements.createdAt)).limit(3),
  db.select().from(duesPayments).where(
    and(eq(duesPayments.userId, user.id), eq(duesPayments.status, "pending"))
  ).orderBy(duesPayments.dueDate).limit(5),
]);


const totalOwed = myDues.reduce((sum, d) => sum + parseFloat(d.amount), 0);
---
<App title="Dashboard">
  <div class="max-w-5xl">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-1">Welcome back, {user.firstName}</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mb-8">{format(new Date(), "EEEE, MMMM d, yyyy")}</p>

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
        <p class="text-sm text-gray-500 dark:text-gray-400">Balance Due</p>
        <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1">${totalOwed.toFixed(2)}</p>
        {totalOwed > 0 && <a href="/payments" class="text-sm text-blue-600 hover:underline mt-2 inline-block">Pay now</a>}
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
        <p class="text-sm text-gray-500 dark:text-gray-400">Pending Dues</p>
        <p class="text-2xl font-bold text-gray-900 dark:text-white mt-1">{myDues.length}</p>
        <a href="/payments" class="text-sm text-blue-600 hover:underline mt-2 inline-block">View details</a>
      </div>
    </div>

    <!-- Announcements -->
    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
      <div class="flex justify-between items-center mb-4">
        <h2 class="font-semibold text-gray-900 dark:text-white">Announcements</h2>
        <a href="/announcements" class="text-sm text-blue-600 hover:underline">View all</a>
      </div>
      {recentAnnouncements.length === 0 ? (
        <p class="text-sm text-gray-500 dark:text-gray-400">No announcements yet.</p>
      ) : (
        <div class="space-y-3">
          {recentAnnouncements.map((a) => (
            <div class="border-b border-gray-100 dark:border-gray-700 pb-3 last:border-0 last:pb-0">
              <p class="text-sm font-medium text-gray-900 dark:text-white">{a.title}</p>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">{format(new Date(a.createdAt!), "MMM d, yyyy")}</p>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</App>
