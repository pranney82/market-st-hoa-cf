---
import Base from "../layouts/Base.astro";
---
<Base title="Not Found">
  <div class="min-h-screen flex items-center justify-center bg-gray-50">
    <div class="text-center">
      <p class="text-6xl font-bold text-gray-200">404</p>
      <h1 class="text-xl font-bold text-gray-900 mt-4">Page not found</h1>
      <p class="text-sm text-gray-500 mt-2">The page you're looking for doesn't exist.</p>
      <a href="/dashboard" class="inline-block mt-6 px-5 py-3 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700">Go to Dashboard</a>
    </div>
  </div>
</Base>
