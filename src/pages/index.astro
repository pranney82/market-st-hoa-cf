---
export const prerender = true;
import Base from "../layouts/Base.astro";
---
<Base title="Welcome">
 <div class="min-h-[100dvh] bg-[#fafaf9] flex flex-col">
 <!-- Header -->
 <header class="relative z-20 px-5 py-4 md:px-8 md:py-5">
 <div class="max-w-5xl mx-auto flex justify-between items-center">
 <div class="flex items-center gap-2.5">
 <img src="/icons/frame.svg" alt="" class="w-8 h-8 rounded-lg" />
 <span class="font-semibold text-gray-900 text-[15px] tracking-tight">Market St HOA</span>
 </div>
 <a href="/dashboard" class="px-4 py-3 text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors rounded-lg">
 Sign In
 </a>
 </div>
 </header>

 <!-- Hero -->
 <main class="flex-1 flex flex-col">
 <div class="relative flex-1 flex flex-col items-center justify-center px-5 md:px-8 pt-8 pb-16 md:pt-12 md:pb-20">
 <!-- Background -->
 <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
 <!-- Warm gradient wash -->
 <div class="absolute inset-0 opacity-60" style="background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(59,130,246,0.08) 0%, transparent 60%), radial-gradient(ellipse 60% 50% at 80% 100%, rgba(251,191,36,0.06) 0%, transparent 50%);"></div>
 <!-- Grid pattern -->
 <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(0,0,0,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.1) 1px, transparent 1px); background-size: 48px 48px;"></div>
 </div>

 <div class="relative text-center max-w-xl mx-auto animate-fade-in">
 <!-- Neighborhood illustration -->
 <div class="flex items-end justify-center gap-1.5 mb-10 opacity-80" aria-hidden="true">
 <div class="flex flex-col items-center">
 <div class="w-3 h-3 border-l-[6px] border-r-[6px] border-b-[6px] border-l-transparent border-r-transparent border-b-amber-300"></div>
 <div class="w-6 h-8 bg-amber-200/80 rounded-sm"></div>
 </div>
 <div class="flex flex-col items-center">
 <div class="w-3 h-3 border-l-[8px] border-r-[8px] border-b-[8px] border-l-transparent border-r-transparent border-b-blue-300"></div>
 <div class="w-8 h-12 bg-blue-200/80 rounded-sm relative">
 <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-2.5 h-3.5 bg-blue-400/50 rounded-t-sm"></div>
 </div>
 </div>
 <div class="flex flex-col items-center">
 <div class="w-3 h-3 border-l-[10px] border-r-[10px] border-b-[10px] border-l-transparent border-r-transparent border-b-emerald-300"></div>
 <div class="w-10 h-16 bg-emerald-200/80 rounded-sm relative">
 <div class="absolute top-2 left-1.5 w-2 h-2 bg-emerald-100/80 rounded-[1px]"></div>
 <div class="absolute top-2 right-1.5 w-2 h-2 bg-emerald-100/80 rounded-[1px]"></div>
 <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-3 h-4 bg-emerald-400/50 rounded-t-sm"></div>
 </div>
 </div>
 <div class="flex flex-col items-center">
 <div class="w-3 h-3 border-l-[7px] border-r-[7px] border-b-[7px] border-l-transparent border-r-transparent border-b-violet-300"></div>
 <div class="w-7 h-10 bg-violet-200/80 rounded-sm"></div>
 </div>
 <div class="flex flex-col items-center">
 <div class="w-3 h-3 border-l-[6px] border-r-[6px] border-b-[6px] border-l-transparent border-r-transparent border-b-rose-300"></div>
 <div class="w-6 h-7 bg-rose-200/80 rounded-sm"></div>
 </div>
 </div>

 <h1 class="text-[2rem] sm:text-4xl md:text-[2.75rem] font-bold tracking-tight leading-[1.15] text-gray-900 mb-4">
 Your neighborhood,<br/>one&nbsp;tap&nbsp;away
 </h1>

 <p class="text-base md:text-lg text-gray-500 mb-8 max-w-sm mx-auto leading-relaxed">
 Pay&nbsp;dues, vote&nbsp;on&nbsp;proposals, access&nbsp;documents, and stay connected with your community.
 </p>

 <a href="/dashboard" class="group inline-flex items-center justify-center gap-2.5 px-7 py-3.5 bg-gray-900 text-white rounded-full text-sm font-semibold hover:bg-gray-800 transition-all hover:shadow-lg active:scale-[0.98]">
 Open Portal
 <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
 </a>

 <p class="mt-4 text-xs text-gray-400">
 Secured by Cloudflare Access &middot; Members only
 </p>
 </div>
 </div>

 <!-- Features -->
 <div class="relative px-5 md:px-8 pb-16 md:pb-20">
 <div class="max-w-3xl mx-auto">
 <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
 <div class="group flex items-start gap-4 p-4 rounded-2xl bg-white border border-gray-200/70 hover:border-gray-300 transition-all">
 <div class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center shrink-0 mt-0.5">
 <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z"/></svg>
 </div>
 <div>
 <p class="text-sm font-semibold text-gray-900">Pay Dues Online</p>
 <p class="text-sm text-gray-500 mt-0.5 leading-relaxed">Card or ACH payments with instant receipts and payment history.</p>
 </div>
 </div>

 <div class="group flex items-start gap-4 p-4 rounded-2xl bg-white border border-gray-200/70 hover:border-gray-300 transition-all">
 <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center shrink-0 mt-0.5">
 <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
 </div>
 <div>
 <p class="text-sm font-semibold text-gray-900">Vote on Proposals</p>
 <p class="text-sm text-gray-500 mt-0.5 leading-relaxed">Secure digital ballots with real-time results and full transparency.</p>
 </div>
 </div>

 <div class="group flex items-start gap-4 p-4 rounded-2xl bg-white border border-gray-200/70 hover:border-gray-300 transition-all">
 <div class="w-10 h-10 rounded-xl bg-violet-50 flex items-center justify-center shrink-0 mt-0.5">
 <svg class="w-5 h-5 text-violet-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
 </div>
 <div>
 <p class="text-sm font-semibold text-gray-900">Community Documents</p>
 <p class="text-sm text-gray-500 mt-0.5 leading-relaxed">Bylaws, meeting minutes, budgets, and governing docs in one place.</p>
 </div>
 </div>

 <div class="group flex items-start gap-4 p-4 rounded-2xl bg-white border border-gray-200/70 hover:border-gray-300 transition-all">
 <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center shrink-0 mt-0.5">
 <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456Z"/></svg>
 </div>
 <div>
 <p class="text-sm font-semibold text-gray-900">AI Bylaws Assistant</p>
 <p class="text-sm text-gray-500 mt-0.5 leading-relaxed">Ask questions about your HOA rules and get instant, accurate answers.</p>
 </div>
 </div>
 </div>
 </div>
 </div>
 </main>

 <!-- Footer -->
 <footer class="relative z-10 border-t border-gray-200/60 py-6 px-5 md:px-8">
 <div class="max-w-5xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-3">
 <div class="flex items-center gap-2">
 <img src="/icons/frame.svg" alt="" class="w-5 h-5 rounded" />
 <span class="text-xs text-gray-500">Market Street Homeowners Association</span>
 </div>
 <p class="text-xs text-gray-400">&copy; 2026 Market St HOA. All rights reserved.</p>
 </div>
 </footer>
 </div>

 <style>
 @keyframes fade-in {
 from { opacity: 0; transform: translateY(12px); }
 to { opacity: 1; transform: translateY(0); }
 }
 .animate-fade-in {
 animation: fade-in 0.6s ease-out both;
 }
 </style>
</Base>
