---
import App from "../layouts/App.astro";
import PaymentCheckout from "../components/PaymentCheckout";
import { getDb } from "../lib/db";
import { duesPayments } from "../../shared/schema";
import { eq, desc } from "drizzle-orm";
import { format } from "date-fns";

const user = Astro.locals.user!;
const db = getDb(Astro.locals.runtime.env);

const dues = await db
  .select()
  .from(duesPayments)
  .where(eq(duesPayments.userId, user.id))
  .orderBy(desc(duesPayments.dueDate));


const pending = dues.filter((d) => d.status === "pending" || d.status === "overdue");
const paid = dues.filter((d) => d.status === "paid");
const totalOwed = pending.reduce((s, d) => s + parseFloat(d.amount), 0);

const statusColors: Record<string, string> = {
  paid: "bg-green-100 text-green-700",
  pending: "bg-yellow-100 text-yellow-700",
  overdue: "bg-red-100 text-red-700",
  waived: "bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300",
};
---
<App title="Payments">
  <div class="max-w-4xl">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Payments</h1>

    {totalOwed > 0 && (
      <div class="mb-6">
        <!-- React island: Helcim payment checkout (interactive) -->
        <PaymentCheckout client:load amount={totalOwed} userId={user.id} />
      </div>
    )}

    <!-- Pending Dues -->
    {pending.length > 0 && (
      <div class="mb-6">
        <h2 class="font-semibold text-gray-900 dark:text-white mb-3">Outstanding ({pending.length})</h2>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
          <table class="w-full">
            <thead>
              <tr class="bg-gray-50 dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700">
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Description</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Due Date</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Amount</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
              {pending.map((d) => (
                <tr>
                  <td class="px-4 py-3 text-sm text-gray-900 dark:text-white">{d.description || "Monthly Dues"}</td>
                  <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-400">{format(new Date(d.dueDate), "MMM d, yyyy")}</td>
                  <td class="px-4 py-3 text-sm text-gray-900 dark:text-white text-right font-medium">${parseFloat(d.amount).toFixed(2)}</td>
                  <td class="px-4 py-3">
                    <span class:list={["text-xs font-medium px-2 py-1 rounded-full", statusColors[d.status] || "bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300"]}>
                      {d.status}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )}

    <!-- Payment History -->
    <h2 class="font-semibold text-gray-900 dark:text-white mb-3">History</h2>
    {paid.length === 0 ? (
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-6 text-center text-gray-500 dark:text-gray-400 text-sm">
        No payment history yet.
      </div>
    ) : (
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="bg-gray-50 dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700">
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Description</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Paid Date</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Amount</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
            {paid.map((d) => (
              <tr>
                <td class="px-4 py-3 text-sm text-gray-900 dark:text-white">{d.description || "Monthly Dues"}</td>
                <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-400">{d.paidDate ? format(new Date(d.paidDate), "MMM d, yyyy") : "—"}</td>
                <td class="px-4 py-3 text-sm text-gray-900 dark:text-white text-right">${parseFloat(d.amount).toFixed(2)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</App>
