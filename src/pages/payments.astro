---
import App from "../layouts/App.astro";
import PaymentCheckout from "../components/PaymentCheckout";
import AutopaySetup from "../components/AutopaySetup";
import { getDb } from "../lib/db";
import { duesPayments, systemSettings } from "../../shared/schema";
import { eq, desc } from "drizzle-orm";
import { format } from "date-fns";

const user = Astro.locals.user!;
const db = getDb(Astro.locals.runtime.env);

// Get dues amount for autopay display
const [duesSetting] = await db.select().from(systemSettings).where(eq(systemSettings.key, "monthly_dues_amount"));
const monthlyDuesAmount = parseFloat(duesSetting?.value || "150");

const dues = await db
  .select()
  .from(duesPayments)
  .where(eq(duesPayments.userId, user.id))
  .orderBy(desc(duesPayments.dueDate));

const pending = dues.filter((d) => d.status === "pending" || d.status === "overdue");
const paid = dues.filter((d) => d.status === "paid");
const totalOwed = pending.reduce((s, d) => s + parseFloat(d.amount), 0);

const statusColors: Record<string, string> = {
  paid: "bg-green-100 text-green-700",
  pending: "bg-yellow-100 text-yellow-700",
  overdue: "bg-red-100 text-red-700",
  payment_pending: "bg-blue-100 text-blue-700",
  waived: "bg-gray-100 text-gray-600",
};
---
<App title="Payments">
  <div class="max-w-4xl">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">Payments</h1>

    {totalOwed > 0 && (
      <div class="mb-6">
        <PaymentCheckout client:load amount={totalOwed} userId={user.id} />
      </div>
    )}

    {/* Autopay */}
    <div class="mb-6">
      <AutopaySetup client:load isEnabled={user.autopayEnabled ?? false} duesAmount={monthlyDuesAmount} />
    </div>

    <!-- Pending Dues -->
    {pending.length > 0 && (
      <div class="mb-6">
        <h2 class="font-semibold text-gray-900 mb-3">Outstanding ({pending.length})</h2>

        {/* Desktop table */}
        <div class="hidden md:block bg-white rounded-xl border border-gray-200 overflow-hidden">
          <table class="w-full">
            <thead>
              <tr class="bg-gray-50 border-b border-gray-200">
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Description</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Due Date</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Amount</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {pending.map((d) => (
                <tr class="hover:bg-gray-50">
                  <td class="px-4 py-3 text-sm text-gray-900">{d.description || "Monthly Dues"}</td>
                  <td class="px-4 py-3 text-sm text-gray-600">{format(new Date(d.dueDate), "MMM d, yyyy")}</td>
                  <td class="px-4 py-3 text-sm text-gray-900 text-right font-medium">${parseFloat(d.amount).toFixed(2)}</td>
                  <td class="px-4 py-3">
                    <span class:list={["text-xs font-medium px-2 py-1 rounded-full", statusColors[d.status] || "bg-gray-100 text-gray-600"]}>
                      {d.status}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        {/* Mobile cards */}
        <div class="md:hidden space-y-3">
          {pending.map((d) => (
            <div class="bg-white rounded-xl border border-gray-200 p-4">
              <div class="flex items-start justify-between mb-1">
                <p class="text-sm font-medium text-gray-900">{d.description || "Monthly Dues"}</p>
                <span class:list={["text-xs font-medium px-2 py-0.5 rounded-full shrink-0 ml-2", statusColors[d.status] || "bg-gray-100 text-gray-600"]}>
                  {d.status}
                </span>
              </div>
              <div class="flex items-center justify-between">
                <p class="text-xs text-gray-500">Due {format(new Date(d.dueDate), "MMM d, yyyy")}</p>
                <p class="text-sm font-semibold text-gray-900">${parseFloat(d.amount).toFixed(2)}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Payment History -->
    <h2 class="font-semibold text-gray-900 mb-3">History</h2>
    {paid.length === 0 ? (
      <div class="bg-white rounded-xl border border-gray-200 p-6 text-center text-gray-500 text-sm">
        No payment history yet.
      </div>
    ) : (
      <>
        {/* Desktop table */}
        <div class="hidden md:block bg-white rounded-xl border border-gray-200 overflow-hidden">
          <table class="w-full">
            <thead>
              <tr class="bg-gray-50 border-b border-gray-200">
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Description</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Paid Date</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">Amount</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {paid.map((d) => (
                <tr class="hover:bg-gray-50">
                  <td class="px-4 py-3 text-sm text-gray-900">{d.description || "Monthly Dues"}</td>
                  <td class="px-4 py-3 text-sm text-gray-600">{d.paidDate ? format(new Date(d.paidDate), "MMM d, yyyy") : "—"}</td>
                  <td class="px-4 py-3 text-sm text-gray-900 text-right">${parseFloat(d.amount).toFixed(2)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        {/* Mobile cards */}
        <div class="md:hidden space-y-3">
          {paid.map((d) => (
            <div class="bg-white rounded-xl border border-gray-200 p-4">
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-sm font-medium text-gray-900">{d.description || "Monthly Dues"}</p>
                  <p class="text-xs text-gray-500">{d.paidDate ? format(new Date(d.paidDate), "MMM d, yyyy") : "—"}</p>
                </div>
                <p class="text-sm font-medium text-gray-900">${parseFloat(d.amount).toFixed(2)}</p>
              </div>
            </div>
          ))}
        </div>
      </>
    )}
  </div>
</App>
