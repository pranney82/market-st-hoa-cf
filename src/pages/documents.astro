---
import App from "../layouts/App.astro";
import { getDb } from "../lib/db";
import { documents } from "../../shared/schema";
import { eq, desc, and } from "drizzle-orm";
import { format } from "date-fns";

const user = Astro.locals.user!;
const isAdmin = user.role === "admin" || user.role === "board";
const db = getDb(Astro.locals.runtime.env);

const conditions = isAdmin ? [] : [eq(documents.isPublic, true)];
const docs = conditions.length > 0
  ? await db.select().from(documents).where(and(...conditions)).orderBy(desc(documents.createdAt))
  : await db.select().from(documents).orderBy(desc(documents.createdAt));


const sizeStr = (bytes: string) => {
  const n = parseInt(bytes);
  if (n < 1024) return `${n} B`;
  if (n < 1048576) return `${(n / 1024).toFixed(1)} KB`;
  return `${(n / 1048576).toFixed(1)} MB`;
};
---
<App title="Documents">
  <div class="max-w-4xl">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Documents</h1>
      {isAdmin && (
        <a href="/documents/upload" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700">
          Upload
        </a>
      )}
    </div>

    {docs.length === 0 ? (
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-8 text-center text-gray-500 dark:text-gray-400">
        No documents available.
      </div>
    ) : (
      <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="bg-gray-50 dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700">
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Name</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Category</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Size</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Uploaded</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
            {docs.map((d) => (
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                <td class="px-4 py-3 text-sm font-medium text-gray-900 dark:text-white">{d.fileName}</td>
                <td class="px-4 py-3">
                  <span class="text-xs bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 px-2 py-1 rounded-full">{d.category || "General"}</span>
                </td>
                <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-400">{sizeStr(d.fileSize)}</td>
                <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-400">{format(new Date(d.createdAt!), "MMM d, yyyy")}</td>
                <td class="px-4 py-3 text-right">
                  <a href={`/api/documents/${d.id}/download`} class="text-sm text-blue-600 hover:underline">Download</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</App>
